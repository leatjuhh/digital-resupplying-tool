# Assist mode voor ML-model integratie
# Opties: off | shadow | rank_assist
# - off: model niet actief
# - shadow: model scoort moves maar beïnvloedt volgorde niet (aanbevolen voor praktijktest)
# - rank_assist: model herschikt moves op combined_score (0.4 demand + 0.6 model)
ALGORITHM_ASSIST_MODE=shadow

# Pad naar de root van de Herverdelingsalgoritme data-directory
# Moet bestaan en de structuur {jaar}/week_{week}/combined.json + aggregate/model_artifacts.json bevatten
# Laat leeg om automatisch het sibling-project ../Herverdelingsalgoritme/data te gebruiken.
# Alleen invullen als de dataset op een andere locatie staat.
EXTERNAL_ALGORITHM_DATA_ROOT=
